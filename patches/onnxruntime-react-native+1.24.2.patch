+  const R* GetTensorData() const;  ///< Wraps OrtApi::GetTensorData   /// <summary>
+
+  /// <summary>
+  /// Returns a non-typed pointer to a tensor contained data.
+  /// </summary>
+  /// <returns>const pointer to data, no copies made</returns>
